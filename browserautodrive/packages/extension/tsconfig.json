{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "rootDir": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome"]
  },
  "include": ["content/**/*", "popup/**/*", "background/**/*", "shared/**/*"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
