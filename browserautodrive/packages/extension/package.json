{
  "name": "@browserautodrive/extension",
  "version": "0.1.0",
  "private": true,
  "description": "BrowserAutoDrive Chrome Extension",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:workers": "node ./scripts/build.mjs",
    "build:popup": "vite build --config ./vite.popup.config.ts",
    "build": "npm run typecheck && npm run build:workers && npm run build:popup",
    "dev": "node ./scripts/build.mjs --watch",
    "dev:popup": "vite build --watch --config ./vite.popup.config.ts"
  },
  "dependencies": {
    "@browserautodrive/core": "*",
    "@browserautodrive/llm": "*",
    "@browserautodrive/safety": "*",
    "esbuild": "^0.25.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@types/chrome": "^0.0.268",
    "typescript": "^5.3.0",
    "vite": "^7.1.12"
  }
}
