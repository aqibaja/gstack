{
  "name": "@browserautodrive/eval",
  "version": "0.1.0",
  "private": true,
  "description": "BrowserAutoDrive evaluation and integration test suite",
  "scripts": {
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@browserautodrive/browser": "^0.1.0",
    "@browserautodrive/core": "^0.1.0",
    "@browserautodrive/llm": "^0.1.0",
    "@browserautodrive/observe": "^0.1.0",
    "@browserautodrive/safety": "^0.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/e2e/"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}
